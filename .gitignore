# =============================================================================
# Transcrição Universal — .gitignore
# Stack: Python 3.11+ / Streamlit / yt-dlp / Whisper / Railway
# =============================================================================

# --- Environment & Secrets (CRITICAL — repo is public) ---
.env
.env.local
.env.*.local
*.key
*.pem
*.crt
secrets/

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover
.hypothesis/
.tox/
.nox/
.mypy_cache/
.ruff_cache/

# --- Virtual environments ---
venv/
.venv/
env/
ENV/
env.bak/
venv.bak/

# --- Build artifacts ---
dist/
build/
*.egg-info/
*.egg
develop-eggs/
downloads/
eggs/
.eggs/
parts/
sdist/
wheels/
share/python-wheels/
MANIFEST

# --- Logs ---
*.log
logs/
pip-log.txt
pip-delete-this-directory.txt

# --- Node (if any tooling sneaks in) ---
node_modules/
package-lock.json.bak

# --- IDE & OS ---
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
*~

# --- AI tooling sidecar dirs (don't pollute repo) ---
.agent/
.antigravity/
.codex/
.cursor/
.gemini/

# --- Streamlit runtime ---
.streamlit/secrets.toml

# --- ffmpeg/yt-dlp temp artifacts ---
*.part
*.ytdl
tmp/
temp/

# --- Audio test fixtures (large binaries) ---
*.mp3
*.m4a
*.wav
*.ogg
!tests/fixtures/*.mp3

# --- AIOX Local (framework runtime) ---
.aiox/license.cache
.aiox/install-log.txt
.aiox/handoffs/
.claude/settings.local.json
.claude/scheduled_tasks.lock
.aiox-core/local/
.aiox-core/node_modules/
