{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "squad-config-pro.schema.json",
  "title": "AIOX Squad Config Pro Schema",
  "description": "Validates squad-creator-pro config.yaml — governance framework compliance. Extends base schema with pro-specific fields (features, pro_stats, enhances).",
  "type": "object",
  "required": ["name", "version", "description", "type", "enhances"],
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$",
      "description": "Squad name in kebab-case"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantic version"
    },
    "type": {
      "type": "string",
      "enum": ["upgrade-pack", "standalone", "base"],
      "description": "Squad type — upgrade-pack extends a base squad"
    },
    "enhances": {
      "type": "string",
      "description": "Base squad this pack extends (e.g., squad-creator)"
    },
    "tested": {
      "type": "boolean",
      "description": "Whether squad has passed validation"
    },
    "description": {
      "type": "string",
      "minLength": 10,
      "description": "Squad purpose description"
    },
    "quality_threshold": {
      "type": "number",
      "minimum": 0,
      "maximum": 10
    },
    "features": {
      "type": "object",
      "description": "Feature manifest — pro capabilities grouped by domain",
      "additionalProperties": {
        "type": "object",
        "required": ["description"],
        "properties": {
          "description": { "type": "string" },
          "agents": { "type": "array", "items": { "type": "string" } },
          "tasks": { "type": "array", "items": { "type": "string" } },
          "workflows": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "workspace_integration": {
      "type": "object",
      "required": ["level"],
      "properties": {
        "level": {
          "type": "string",
          "enum": ["none", "read_only", "controlled_runtime_consumer", "workspace_first"]
        },
        "rationale": { "type": "string" },
        "read_paths": { "type": "array", "items": { "type": "string" } },
        "write_paths": { "type": "array", "items": { "type": "string" } },
        "documents_owned": { "type": "array", "items": { "type": "string" } }
      }
    },
    "artifact_contracts": {
      "type": "array",
      "description": "Governance framework — artifacts produced by this squad",
      "items": {
        "type": "object",
        "required": ["artifact_id", "template_path"],
        "properties": {
          "artifact_id": { "type": "string" },
          "template_path": { "type": "string" },
          "lifecycle_states": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["draft", "pending_validation", "validated", "approved", "rejected", "consumed", "superseded", "archived"]
            }
          }
        }
      }
    },
    "artifact_lifecycle": {
      "type": "object",
      "properties": {
        "tracking_enabled": { "type": "boolean" },
        "state_persistence": { "type": "string" },
        "transitions": { "type": "array", "items": { "type": "string" } }
      }
    },
    "instance_lifecycle": {
      "type": "object",
      "properties": {
        "tracking_enabled": { "type": "boolean" },
        "state_persistence": { "type": "string" },
        "states": { "type": "array", "items": { "type": "string" } }
      }
    },
    "journey_log": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "template": { "type": "string" },
        "persistence": { "type": "string" }
      }
    },
    "bu_mapping": { "type": "string" },
    "supported_modes": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["CRIAR", "PLANEJAR", "RESOLVER", "ENTENDER", "VALIDAR", "CONFIGURAR", "GERENCIAR", "EXPLORAR"]
      }
    },
    "metadata": {
      "type": "object",
      "properties": {
        "version": { "type": "string" },
        "type": { "type": "string" },
        "enhances": { "type": "string" },
        "base_requirement": { "type": "string" },
        "pro_stats": {
          "type": "object",
          "properties": {
            "agents": { "type": "integer" },
            "tasks": { "type": "integer" },
            "workflows": { "type": "integer" },
            "configs": { "type": "integer" },
            "checklists": { "type": "integer" },
            "scripts": { "type": "integer" },
            "test_scripts": { "type": "integer" },
            "data_files": { "type": "integer" },
            "minds": { "type": "integer" },
            "test_cases": { "type": "integer" }
          }
        }
      }
    }
  }
}
